# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_USER_FOLDER=./n8n-data
WEBHOOK_URL=http://localhost:5678

# n8n API key (Settings > n8n API > Create API key)
N8N_API_KEY=

# ── AI API Keys ───────────────────────────────────────────────────────────────
# These are optional — the frontend can also pass keys via x-api-key header.
# Setting them here keeps keys off the client and out of browser storage.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
