{
  "name": "personal-studio",
  "version": "1.0.0",
  "description": "Personal AI Creative Workspace with n8n workflow automation",
  "main": "server.js",
  "scripts": {
    "start": "concurrently --names \"SERVER,N8N\" --prefix-colors \"cyan,magenta\" \"node server.js\" \"n8n start\"",
    "dev": "concurrently --names \"SERVER,N8N\" --prefix-colors \"cyan,magenta\" \"node --watch server.js\" \"n8n start\"",
    "server": "node server.js",
    "n8n": "n8n start",
    "setup": "npm install && npm install -g n8n"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
